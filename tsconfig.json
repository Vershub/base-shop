{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "strict": true,
        "noUnusedParameters": true,
        "jsx": "preserve",
        "importHelpers": true,
        "experimentalDecorators": true,
        "sourceMap": true,
        "allowSyntheticDefaultImports": true,
        "moduleResolution": "bundler",
        "baseUrl": ".",
        "types": ["vite/client", "node", "@vue/runtime-core", "vue"],
        "paths": {
            "@/*": ["resources/js/*"],
            "vue": ["./node_modules/vue"]
        },
        "lib": ["ESNext", "DOM", "DOM.Iterable"],
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "esModuleInterop": true
    },
    "include": [
        "resources/js/**/*.ts",
        "resources/js/**/*.d.ts",
        "resources/js/**/*.tsx",
        "resources/js/**/*.vue",
        "resources/js/shims-vue.d.ts"
    ],
    "exclude": ["node_modules"]
}
