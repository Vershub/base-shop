#!/bin/sh

echo "Running PHPStan analysis before commit..."

# Run PHPStan
composer phpstan

# Capture the exit code of PHPStan
RESULT=$?

if [ $RESULT -ne 0 ]; then
    echo "❌ PHPStan detected issues! Fix them before committing."
    exit 1 # This stops the commit
fi

echo "✅ PHPStan passed. Proceeding with commit."
exit 0 # This allows the commit


